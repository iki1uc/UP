<script>
window.addEventListener("message", (event) => {
    const d = event.data;
    if(!d || !d.FROM || !d.TO) return;

    // Visuelle Bestätigung
    document.body.style.border = "2px solid #6cf";

    // Terminal-Ausgabe
    console.log("MSG:", d);

    // Ausgabe im UI (falls vorhanden)
    const out = document.getElementById("station_out");
    if(out){
        out.innerHTML += `\nFROM: ${d.FROM} → TO: ${d.TO}`;
    }
});
</script>
